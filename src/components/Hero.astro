---
import { Image } from "astro:assets";
import portrait from "../assets/portrait.jpg";

const ctas = [
  { href: "mailto:nahuelborromeo@gmail.com", label: "Email me", primary: true },
  { href: "https://www.linkedin.com/in/nahuel-borromeo/", label: "LinkedIn" },
  { href: "https://github.com/NahuelBorromeo", label: "GitHub" },
  { href: "/cv.pdf", label: "Download CV" },
];
---

<section class="mx-auto max-w-5xl px-6 pt-20 pb-24 sm:pt-28 sm:pb-32">
  <div class="flex flex-col-reverse items-start gap-10 sm:flex-row sm:items-center sm:justify-between">
    <div class="max-w-2xl">
      <p class="text-accent font-medium">iOS Engineer</p>
      <h1
        class="mt-2 text-5xl font-semibold tracking-tight text-balance sm:text-6xl"
      >
        Nahuel Borromeo
      </h1>
      <p class="mt-6 text-lg leading-relaxed text-ink-2 text-pretty">
        I build production banking apps with Swift, UIKit and SwiftUI — 3+
        years turning complex financial products into simple mobile
        experiences.
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        {
          ctas.map((cta) => (
            <a
              href={cta.href}
              target={cta.href.startsWith("http") ? "_blank" : undefined}
              rel={cta.href.startsWith("http") ? "noopener" : undefined}
              class={
                cta.primary
                  ? "rounded-full bg-accent px-5 py-2.5 text-sm font-medium text-white transition-opacity hover:opacity-85"
                  : "rounded-full border border-line px-5 py-2.5 text-sm font-medium text-ink transition-colors hover:bg-surface"
              }
            >
              {cta.label}
            </a>
          ))
        }
      </div>
    </div>
    <Image
      src={portrait}
      alt="Portrait of Nahuel Borromeo"
      width={352}
      height={352}
      densities={[1, 2]}
      loading="eager"
      class="size-36 rounded-full object-cover ring-1 ring-line sm:size-44"
    />
  </div>
</section>
