---
import ExperienceCard from "./ExperienceCard.astro";

// Copy source: docs/knowledge/content.md — don't invent facts.
const jobs = [
  {
    company: "NTT Data",
    role: "iOS Engineer",
    period: "Aug 2024 — Present · Remote",
    context: "Investments module of Interbank's mobile banking app",
    bullets: [
      "Shipped <strong>Phase 1 and Phase 2</strong> of the investments module end to end — both live in production, helping drive <strong>double-digit percentage growth</strong> in customers acquiring investment products and opening a new revenue line for the bank.",
      "Phase 1: built the app's new investments zone from scratch — the first in-app gateway to mutual funds, term deposits and high-yield savings accounts.",
      "Phase 2: developed the investor-profile flow with personalized recommendations, and the fully native mutual fund purchase experience, previously web-only.",
      "Member of the core code-review group: gatekeep code quality for a <strong>50+ iOS developer team</strong>; proposed improvements adopted into the team's code-styling docs.",
      "Mentored and onboarded a teammate as her technical reference.",
      "Contributed to the UIKit-to-SwiftUI migration and the app's SPM modularization, coordinating daily with UX, Product, Backend, Web, Android and QA.",
    ],
  },
  {
    company: "Bachatours (USA)",
    role: "Freelance Web Developer",
    period: "Sep 2023 — Jul 2024 · Remote",
    context: "Commercial website for a US tourism startup",
    bullets: [
      "Built the business website from scratch and owned its ongoing maintenance and evolution.",
      "Worked directly with the owner to translate business requirements into technical solutions, improving brand visibility and online presence.",
    ],
  },
  {
    company: "Baufest",
    role: "Software Developer (iOS)",
    period: "Mar 2022 — Aug 2023 · Remote",
    context: "MODO — the digital wallet for BBVA Argentina",
    bullets: [
      "Implemented and launched <strong>TransferPull</strong>, a money-transfer feature serving MODO's millions of users.",
      "Built two amortization engines for business-lending products.",
      "Kept legacy systems stable through high-pressure release cycles, ensuring backward compatibility with every ship.",
    ],
  },
  {
    company: "Yobel SCM",
    role: "Software Developer",
    period: "Aug 2021 — Mar 2022 · Remote",
    bullets: [
      "Maintained and enhanced enterprise-level systems.",
      "Implemented new UI components and standardized UI designs across modules.",
    ],
  },
];
---

<section id="experience" class="mx-auto max-w-5xl scroll-mt-20 px-6 py-16">
  <h2 class="text-3xl font-semibold tracking-tight">Experience</h2>
  <div class="mt-8 space-y-5">
    {jobs.map((job) => <ExperienceCard {...job} />)}
  </div>
</section>
