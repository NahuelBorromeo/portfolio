---
interface Props {
  company: string;
  role: string;
  period: string;
  context?: string;
  bullets: string[];
}

const { company, role, period, context, bullets } = Astro.props;
---

<article class="rounded-2xl border border-line bg-surface/60 p-6 sm:p-8">
  <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
    <h3 class="text-lg font-semibold tracking-tight">
      {company} <span class="text-ink-2 font-normal">· {role}</span>
    </h3>
    <p class="text-sm text-ink-2">{period}</p>
  </div>
  {context && <p class="mt-3 text-sm font-medium text-accent">{context}</p>}
  <ul class="mt-4 space-y-2.5">
    {
      bullets.map((bullet) => (
        <li class="flex gap-3 text-[15px] leading-relaxed text-ink-2">
          <span aria-hidden="true" class="mt-2.5 size-1 shrink-0 rounded-full bg-ink-2/60" />
          <span set:html={bullet} />
        </li>
      ))
    }
  </ul>
</article>
