---
import ExperienceCard from "./ExperienceCard.astro";

// Copy source: docs/knowledge/content.md — don't invent facts.
const jobs = [
  {
    company: "NTT Data",
    role: "iOS Engineer",
    period: "Aug 2024 — Present · Remote",
    context: "Investments module of a large-scale banking application",
    bullets: [
      "Shipped <strong>Phase 1 and Phase 2</strong> of the investments module end to end — both live in production today.",
      "Helped drive <strong>double-digit percentage growth</strong> in customers opening investment products, turning the module into a new revenue line for the bank.",
      "Own features across Domain / Data / Presentation layers (Clean Architecture, MVVM) in Swift, UIKit and SwiftUI, keeping the codebase testable as it scales.",
      "Partner daily with backend and QA teams in an agile environment.",
    ],
  },
  {
    company: "Bachatours (USA)",
    role: "Freelance Developer",
    period: "Nov 2023 — Feb 2024 · Remote",
    context: "Commercial website for a US tourism startup",
    bullets: [
      "Built the company's commercial website, improving brand visibility and online presence.",
      "Worked directly with stakeholders to translate business requirements into technical solutions.",
    ],
  },
  {
    company: "Baufest",
    role: "Software Developer (iOS)",
    period: "Mar 2022 — Aug 2023 · Remote",
    context: "MODO — the digital wallet for BBVA Argentina",
    bullets: [
      "Implemented and launched <strong>TransferPull</strong>, a money-transfer feature serving MODO's millions of users.",
      "Built two amortization engines for business-lending products.",
      "Kept legacy systems stable through high-pressure release cycles, ensuring backward compatibility with every ship.",
    ],
  },
  {
    company: "Yobel SCM",
    role: "Software Developer",
    period: "Aug 2021 — Mar 2022 · Remote",
    bullets: [
      "Maintained and enhanced enterprise-level systems.",
      "Implemented new UI components and standardized UI designs across modules.",
    ],
  },
];
---

<section id="experience" class="mx-auto max-w-5xl scroll-mt-20 px-6 py-16">
  <h2 class="text-3xl font-semibold tracking-tight">Experience</h2>
  <div class="mt-8 space-y-5">
    {jobs.map((job) => <ExperienceCard {...job} />)}
  </div>
</section>
