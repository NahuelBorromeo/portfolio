---
import { formatDate, type Post } from "../lib/blog";

interface Props {
  post: Post;
}

const { post } = Astro.props;
---

<a
  href={`/blog/${post.id}`}
  class="group block rounded-2xl border border-line p-6 transition-colors hover:bg-surface"
>
  <div class="flex items-baseline justify-between gap-4">
    <h3
      class="font-semibold tracking-tight text-balance group-hover:text-accent transition-colors"
    >
      {post.data.title}
    </h3>
    <time
      datetime={post.data.pubDate.toISOString()}
      class="shrink-0 text-sm text-ink-2"
    >
      {formatDate(post.data.pubDate)}
    </time>
  </div>
  <p class="mt-2 text-sm leading-relaxed text-ink-2">
    {post.data.description}
  </p>
</a>
